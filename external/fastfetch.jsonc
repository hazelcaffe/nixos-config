{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "nixos_small",
        "padding": {
            "top": 1,
            "right": 3
        }
    },
    "display": {
        "separator": "  ",
        "color": {
            "keys": "magenta",
            "title": "magenta"
        }
    },
    "modules": [
        "break",
        {
            "type": "title",
            "key": "󰊠"
        },
        {
            "type": "separator",
            "string": " ───────────────────────────── "
        },
        {
            "type": "os",
            "key": "  OS"
        },
        {
            "type": "host",
            "key": "󰌢  Host"
        },
        {
            "type": "kernel",
            "key": "󰌽  Kernel"
        },
        {
            "type": "uptime",
            "key": "󰅐  Uptime"
        },
        {
            "type": "packages",
            "key": "󰏖  Packages"
        },
        {
            "type": "shell",
            "key": "  Shell"
        },
        {
            "type": "de",
            "key": "󰧨  DE"
        },
        {
            "type": "cpu",
            "key": "  CPU"
        },
        {
            "type": "gpu",
            "key": "󰢮  GPU"
        },
        {
            "type": "memory",
            "key": "󰍛  Memory"
        },
        {
            "type": "disk",
            "key": "󰋊  Disk"
        },
        {
            "type": "colors",
            "paddingLeft": 2,
            "symbol": "circle"
        }
    ]
}
