[general]
framerate = 60
bars = 0
bar_width = 2
bar_spacing = 1
autosens = 1
sensitivity = 100

[input]
method = pulse
source = auto

[output]
method = ncurses
channels = stereo
mono_option = average
reverse = 0
raw_target = /dev/stdout
data_format = binary
bit_format = 16bit

[color]
gradient = 1
gradient_count = 6
gradient_color_1 = '#94e2d5'
gradient_color_2 = '#89b4fa'
gradient_color_3 = '#cba6f7'
gradient_color_4 = '#f5c2e7'
gradient_color_5 = '#fab387'
gradient_color_6 = '#f38ba8'

[smoothing]
integral = 77
monstercat = 1
waves = 0
gravity = 100
