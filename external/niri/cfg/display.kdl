// ────────────── Output Configuration ──────────────
// Connector/mode can be checked without niri from /sys/class/drm/card*-*/status
// and /sys/class/drm/card*-*/modes. This machine currently has DP-1 connected.
// https://github.com/YaLTeR/niri/wiki/Configuration:-Outputs

output "DP-1" {
    mode "2560x1440@180.000"
    scale 1
}
